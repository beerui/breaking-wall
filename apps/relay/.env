# Relay env
RELAY_PORT=8787
AUDIT_JSONL_PATH=./var/audit.jsonl

# allowlist（为空=不限制；建议填你的 user_id）
ALLOWED_FEISHU_USER_IDS=

# agent tokens（至少一个，格式：agent1=token1;agent2=token2）
AGENT_TOKENS=main=change-me

# work roots（cwd 必须在这些根目录下）
WORK_ROOTS=D:/2026/breaking-wall-workspace

# transport mode（pty 或 tmux）
TRANSPORT_MODE=tmux

# Feishu
FEISHU_APP_ID=cli_a93d2fde327adcb0
FEISHU_APP_SECRET=ZZ6H7Czv4DKl5kym7BpXvdUBpvOTBFnM
# 可选：事件订阅验证 token
FEISHU_VERIFICATION_TOKEN=
# 可选：如果飞书事件启用“加密方式”，需要设置该 key，并会校验 x-lark-signature
FEISHU_ENCRYPT_KEY=
