# Relay env
RELAY_PORT=8787
AUDIT_JSONL_PATH=./var/audit.jsonl

# allowlist（为空=不限制；建议填你的 user_id）
ALLOWED_FEISHU_USER_IDS=

# agent tokens（至少一个，格式：agent1=token1;agent2=token2）
AGENT_TOKENS=main=change-me

# work roots（cwd 必须在这些根目录下）
WORK_ROOTS=D:/2026

# transport mode: "pty"（默认，agent 管理 node-pty）或 "tmux"（共享 tmux 会话）
TRANSPORT_MODE=pty

# Feishu
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 可选：事件订阅验证 token
FEISHU_VERIFICATION_TOKEN=
# 可选：如果飞书事件启用“加密方式”，需要设置该 key，并会校验 x-lark-signature
FEISHU_ENCRYPT_KEY=
