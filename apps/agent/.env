# Agent env
RELAY_WS_URL=wss://wall.motou2019.vip/agent
AGENT_ID=main
AGENT_TOKEN=change-me

# 代理设置（会传递给 tmux session 中的 CLI）
HTTP_PROXY=http://127.0.0.1:7897
HTTPS_PROXY=http://127.0.0.1:7897

# Anthropic API 配置（用于自定义 API endpoint 和认证）
ANTHROPIC_BASE_URL=https://anyrouter.top
ANTHROPIC_AUTH_TOKEN=sk-U1opdkT5C9iG5pwzs3u8IWprYJ5LJ16eE5jFRo9pGoH3rja4
ANTHROPIC_DEFAULT_OPUS_MODEL=claude-haiku-4-5
ANTHROPIC_DEFAULT_SONNET_MODEL=claude-haiku-4-5

# CLI commandlines（按你的机器实际情况修改）
CC_CMDLINE=claude
CX_CMDLINE=codex

# shared tmux targets（WSL 内的 session:pane）
TMUX_SESSION_TARGETS=cc=bw-cc:0;cx=bw-cx:0

# work roots（与 relay 保持一致）
WORK_ROOTS=D:/2026/breaking-wall-workspace

# streaming
STREAM_IDLE_MS=1200
MAX_CHUNK_LEN=2000

# timeouts
FIRST_OUTPUT_TIMEOUT_MS=120000
