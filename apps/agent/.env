# Agent env
RELAY_WS_URL=wss://wall.motou2019.vip/agent
AGENT_ID=main
AGENT_TOKEN=change-me

# CLI commandlines（按你的机器实际情况修改）
CC_CMDLINE=claude
CX_CMDLINE=codex

# shared tmux targets（WSL 内的 session:pane）
TMUX_SESSION_TARGETS=cc=bw-cc:0;cx=bw-cx:0

# work roots（与 relay 保持一致）
WORK_ROOTS=D:/2026/breaking-wall-workspace

# streaming
STREAM_IDLE_MS=1200
MAX_CHUNK_LEN=2000

# timeouts
FIRST_OUTPUT_TIMEOUT_MS=120000
